# KiamiCloud — Variáveis de ambiente (EXEMPLO)
# Copiar para .env local e preencher — NUNCA commitar .env real

# Firebase (apenas referência — credenciais reais via FlutterFire CLI)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_WEB_API_KEY=your-web-api-key

# Cloudflare Workers (configurar via wrangler.toml + secrets)
# wrangler secret put FIREBASE_PROJECT_ID
# Não colocar chaves R2 aqui — usar bindings Wrangler

# API
KIAMICLOUD_API_BASE_URL=https://api.kiamicloud.dev
