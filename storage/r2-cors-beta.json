{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://kiamicloud.web.app",
          "https://kiamicloud.firebaseapp.com",
          "http://localhost:8080",
          "http://localhost:5000"
        ],
        "methods": ["GET", "PUT", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag", "Content-Length"],
      "maxAgeSeconds": 3600
    }
  ]
}
